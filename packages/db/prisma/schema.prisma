// AfroHit Studio — Prisma schema
// Standard PostgreSQL only — NO extensions required, so it deploys on any
// managed Postgres (incl. Railway's default / free tier).
//
// Geo: share events store plain lat/lng floats; the heatmap aggregates with
//      AVG() per country/region (a country-level centroid — identical result to
//      the old PostGIS ST_Centroid, no extension needed).
// Vectors: memory embeddings are stored as JSON for future semantic search;
//      retrieval currently uses recency, so no pgvector needed yet.
//
// Conventions:
//   - All IDs are CUIDs.
//   - All timestamps stored as `timestamptz`.
//   - Multi-tenant: every business row carries `workspaceId`.
//   - Soft-deletion via `deletedAt` where data matters historically.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Tenancy + Identity
// ===========================================================================

model Workspace {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  plan                 Plan      @default(STARTER)
  creditsCents         Int       @default(0) // credit balance in 1/100 cents (precision)
  paypalSubscriptionId String?   @unique // PayPal Subscription ID (BA-... / I-...) for the active plan
  musicProvider        String? // "replicate" | "suno" | null → falls back to env/stub
  musicApiKey          String? // provider API key set in-app (internal tenant; keep DB private)
  createdAt            DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt            DateTime?
  suspendedAt          DateTime? // admin suspension — auth middleware rejects with 403

  members              WorkspaceMember[]
  artists              Artist[]
  projects             Project[]
  voiceConsents        VoiceConsent[]
  voiceProfiles        VoiceProfile[]
  voiceDatasets        VoiceDataset[]
  likenessConsents     LikenessConsent[]
  artistLikenesses     ArtistLikeness[]
  brandKits            BrandKit[]
  songs                Song[]
  jobs                 ProviderJob[]
  rightsReceipts       RightsReceipt[]
  releaseAttestations  ReleaseAttestation[]
  shareLinks           ShareLink[]
  shareEvents          ShareEvent[]
  artistMemoryChunks   ArtistMemoryChunk[]
  approvals            Approval[]
  releases             Release[]
  benchmarkRatings     BenchmarkRating[]
  benchmarkPairs       BenchmarkPair[]
  benchmarkJudgments   BenchmarkJudgment[]
  chatThreads          ChatThread[]
  ledgerEntries        CreditLedger[]
  analyticsEvents      AnalyticsEvent[]
  albums               Album[]
  materials            MaterialAsset[]
  materialUsages       MaterialUsage[]
  referenceUsages      ReferenceUsage[]
  jobOutbox            JobOutbox[]
  billingIntents       BillingIntent[]
  billingEvents        BillingEvent[]
  billingSubscriptions BillingSubscription[]
  billingEntitlements  BillingEntitlement[]

  @@index([slug])
}

model User {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  email        String   @unique
  fullName     String?
  avatarUrl    String?
  /// scrypt hash "salt:hex" for email+password auth (AUTH_MODE=jwt). Null for
  /// identities created by other means (internal owner, future OAuth).
  passwordHash String?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  memberships           WorkspaceMember[]
  chatThreads           ChatThread[]
  approvals             Approval[]
  voiceConsents         VoiceConsent[]
  likenessConsents      LikenessConsent[]
  benchmarkPairsCreated BenchmarkPair[]     @relation("BenchmarkPairCreator")
  benchmarkJudgments    BenchmarkJudgment[] @relation("BenchmarkJudge")
  passwordResetTokens   PasswordResetToken[]
}

/// PASSWORD RESET (forgotten-password flow, 2026-07-20). A single-use, expiring
/// grant to set a new password without knowing the old one. SECURITY: only the
/// SHA-256 hash of the opaque token is stored (`tokenHash`), never the token
/// itself — a database leak cannot be replayed. `expiresAt` bounds the window
/// (~1h); `usedAt` enforces single use. Anti-enumeration lives in the route:
/// request-reset always answers the same whether or not the email exists.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime  @db.Timestamptz(6)
  usedAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(OWNER)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

enum Role {
  OWNER
  ADMIN
  PRODUCER
  WRITER
  VOCALIST
  VIEWER
}

enum Plan {
  STARTER
  CREATOR
  PRO
  STUDIO
}

// ===========================================================================
// Artist identity (the DNA)
// ===========================================================================

model Artist {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String
  stageName       String
  bio             String?
  // Vocal DNA
  vocalRangeLow   String? // e.g. "G2"
  vocalRangeHigh  String? // e.g. "C5"
  vocalTone       String[] @default([]) // "smooth", "raspy", "nasal", "airy"
  defaultBpmMin   Int?
  defaultBpmMax   Int?
  // Languages the artist can deliver naturally
  languages       String[] @default([]) // ISO-ish: "yo","ig","ha","pcm","en"
  // Style lane (free-text + tags)
  laneSummary     String?  @db.Text
  references      Json? // [{name:"Wizkid", lane:"smooth", note:"pocket reference only"}]
  forbiddenStyles String[] @default([])
  slang           Json? // [{phrase:"omo", meaning:"man/exclam", language:"pcm"}]
  approvedPhrases Json?
  cornyBanned     String[] @default([])
  // Automation flags
  morningDrop     Boolean  @default(false) // nightly cron: generate + score hooks, email top 10
  autoPilot       Boolean  @default(false) // legacy compatibility only; API input/output omits this field
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects         Project[]
  voiceProfiles    VoiceProfile[]
  voiceConsents    VoiceConsent[]
  brandKits        BrandKit[]
  releases         Release[]
  memoryChunks     ArtistMemoryChunk[]
  likenessConsents LikenessConsent[]
  likenesses       ArtistLikeness[]

  @@index([workspaceId])
}

// ===========================================================================
// Voice (consent + cloned profile)
// ===========================================================================

model VoiceConsent {
  id              String    @id @default(cuid())
  workspaceId     String
  artistId        String?
  signerUserId    String?
  legalName       String
  email           String
  consentText     String    @db.Text
  consentVersion  String    @default("legacy")
  consentTextHash String?
  consentAudioUrl String? // recorded statement reading the disclosure
  signatureUrl    String? // signature image
  ipAddress       String? // legacy only; purged by the versioned-consent migration
  ipHash          String?
  userAgent       String?
  signedAt        DateTime  @default(now()) @db.Timestamptz(6)
  revokedAt       DateTime?

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  artist        Artist?        @relation(fields: [artistId], references: [id], onDelete: Cascade)
  signer        User?          @relation(fields: [signerUserId], references: [id], onDelete: SetNull)
  voiceProfiles VoiceProfile[]

  @@index([workspaceId])
  @@index([artistId])
  @@index([signerUserId])
}

// TRAINING-LICENSE CONSENT (the consent door, 2026-07-19) — the versioned,
// hashed, revocable grant that lets a workspace's USER-ORIGINAL uploads count
// as training fuel. Mirrors VoiceConsent's shape; resolved by the pure
// resolveTrainingConsent() in @afrohit/shared (fail-closed: no record, revoked,
// or clause-hash mismatch all deny). Captured at signup (ToS-on-signup) and
// grantable/revocable via the admin training endpoints.
model TrainingConsent {
  id              String    @id @default(cuid())
  workspaceId     String
  grantedByUserId String?
  consentText     String    @db.Text
  consentVersion  String
  consentTextHash String?
  signedAt        DateTime  @default(now()) @db.Timestamptz(6)
  revokedAt       DateTime?

  @@index([workspaceId, revokedAt])
}

model VoiceProfile {
  id               String             @id @default(cuid())
  workspaceId      String
  artistId         String
  consentId        String
  name             String
  provider         String // "eleven" (speech clone) | "replicate" (RVC conversion) | "stub" (local tests only)
  providerVoiceId  String? // external ID from the provider
  status           VoiceProfileStatus @default(PENDING)
  sampleUrls       String[]           @default([]) // raw uploaded samples
  language         String? // primary language
  meta             Json?
  // OWN-VOICE TRAINING (Replicate trainings API): the artist trains a singing
  // model on HIS OWN recordings; weights land in HIS Replicate account.
  trainingId       String? // Replicate training id (polled via GET /voices/:id/training)
  destinationModel String? // "user/model" destination in the artist's Replicate account (keep private)
  trainedVersion   String? // version identifier once training succeeds
  voiceDatasetId   String?
  trainingMeta     Json? // {datasetZipUrl, trainer, at, externalDataset?, output?, error?}
  createdAt        DateTime           @default(now()) @db.Timestamptz(6)

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  artist       Artist        @relation(fields: [artistId], references: [id], onDelete: Cascade)
  consent      VoiceConsent  @relation(fields: [consentId], references: [id])
  vocalRenders VocalRender[]
  voiceDataset VoiceDataset? @relation(fields: [voiceDatasetId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([artistId])
  @@index([voiceDatasetId])
}

model VoiceDataset {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  url          String   @unique
  contentHash  String
  segments     Int
  totalSeconds Int
  qualityState String // "passed" | "failed"
  verifiedAt   DateTime @db.Timestamptz(6)
  meta         Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  voiceProfiles VoiceProfile[]

  @@unique([workspaceId, contentHash])
  @@index([workspaceId, qualityState])
}

enum VoiceProfileStatus {
  PENDING
  TRAINING
  READY
  FAILED
  REVOKED
}

// ===========================================================================
// Likeness (consent + own-face photos + trained visual model)
// ===========================================================================

/// Versioned likeness consent — mirrors VoiceConsent (own-face-only doctrine).
/// A separate model rather than reusing VoiceConsent so revoking a voice never
/// silently kills a likeness (and vice versa), and each consent text stays a
/// verbatim, hashable record of what was actually signed for that modality.
model LikenessConsent {
  id              String    @id @default(cuid())
  workspaceId     String
  artistId        String
  signerUserId    String?
  legalName       String
  email           String
  consentText     String    @db.Text
  consentVersion  String
  consentTextHash String?
  ipHash          String?
  userAgent       String?
  signedAt        DateTime  @default(now()) @db.Timestamptz(6)
  revokedAt       DateTime? @db.Timestamptz(6)

  workspace  Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  artist     Artist           @relation(fields: [artistId], references: [id], onDelete: Cascade)
  signer     User?            @relation(fields: [signerUserId], references: [id], onDelete: SetNull)
  likenesses ArtistLikeness[]

  @@index([workspaceId])
  @@index([artistId])
  @@index([signerUserId])
}

/// One likeness ASSET (an uploaded own-face photo; 'video' reserved for
/// motion reference uploads). Training flips the participating photo rows
/// pending → training → trained/failed and stamps the SAME trainedModelRef on
/// every row that fed the run — "a trained likeness exists" means: a live
/// (non-deleted) trained row with a model ref under an unrevoked consent.
model ArtistLikeness {
  id              String    @id @default(cuid())
  workspaceId     String
  artistId        String
  kind            String // 'photo' | 'video'
  url             String // private storage URI (s3://...), never public
  contentHash     String? // sha256 of the uploaded bytes — dedupe + provenance
  consentId       String
  status          String    @default("pending") // 'pending'|'training'|'trained'|'failed'
  trainedModelRef String? // Replicate "owner/model:version" once trained
  meta            Json? // {trainingJobId, trainer, triggerWord, trainedAt, error?, rightsBasis}
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  deletedAt       DateTime? @db.Timestamptz(6) // soft delete — rows never vanish from provenance

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  artist    Artist          @relation(fields: [artistId], references: [id], onDelete: Cascade)
  consent   LikenessConsent @relation(fields: [consentId], references: [id])

  @@unique([workspaceId, contentHash])
  @@index([workspaceId])
  @@index([artistId, status])
  @@index([consentId])
}

// ===========================================================================
// Brand kit (cover art templates, palette, fonts, captions style)
// ===========================================================================

model BrandKit {
  id          String       @id @default(cuid())
  workspaceId String
  artistId    String?
  name        String
  palette     Json? // [{name:"primary", hex:"#0F172A"}]
  fonts       Json? // [{role:"display", family:"Anton"}]
  voiceTone   String? // "playful", "luxe"
  logoUrl     String?
  styleNotes  String?      @db.Text
  imageAssets ImageAsset[]
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  artist    Artist?   @relation(fields: [artistId], references: [id])

  @@index([workspaceId])
}

// ===========================================================================
// Projects + briefs (a project is a song idea container)
// ===========================================================================

model Project {
  id           String        @id @default(cuid())
  workspaceId  String
  artistId     String
  title        String
  genre        String // "afrobeats","afro_fusion","amapiano","afro_dancehall","gospel","afro_rnb","street_pop","hip_hop"
  bpm          Int?
  keySignature String?
  status       ProjectStatus @default(DRAFT)
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(6)

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  artist              Artist               @relation(fields: [artistId], references: [id], onDelete: Cascade)
  briefs              SongBrief[]
  songs               Song[]
  hooks               HookCandidate[]
  lyrics              LyricDraft[]
  beats               BeatAsset[]
  vocalRenders        VocalRender[]
  mixes               Mix[]
  masters             Master[]
  imageAssets         ImageAsset[]
  videoConcepts       VideoConcept[]
  videoRenders        VideoRender[]
  approvals           Approval[]
  rightsReceipts      RightsReceipt[]
  releaseAttestations ReleaseAttestation[]
  exports             Export[]
  jobs                ProviderJob[]
  chatThreads         ChatThread[]

  @@index([workspaceId])
  @@index([artistId])
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  REVIEW
  APPROVED
  RELEASED
  ARCHIVED
}

model SongBrief {
  id         String   @id @default(cuid())
  projectId  String
  mood       String?
  topic      String?  @db.Text
  language   String[] @default([]) // ["pcm","yo"]
  audience   String? // "club","romantic","streets","gospel"
  bpm        Int?
  references Json? // optional vibe refs (lane references, NOT clones)
  notes      String?  @db.Text
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ===========================================================================
// Songs (a project can have multiple finished song versions)
// ===========================================================================

// THE MATERIAL LAYER — real, owned musical material the AI ARRANGES instead of
// asking a text-to-audio model to hallucinate everything. Sources: the artist's
// workspace stems + generated/licensed loops, with origin and rights recorded.
// This is the "exact beat" foundation.
model MaterialAsset {
  id           String    @id @default(cuid())
  workspaceId  String
  kind         String // 'loop' | 'stem'
  role         String // 'drums' | 'log_drum' | 'bass' | 'percussion' | 'chords' | 'melody' | 'other'
  genre        String?
  bpm          Int?
  keySignature String?
  bars         Int?
  durationS    Float?
  url          String
  source       String // 'forged' (studio-generated isolated loop) | 'artist_stem'
  meta         Json? // qc, forge prompt, origin beat/song ids
  // Material truth spine. "ready" means technically safe to assemble; the
  // separate roleEvidence field says how strongly the claimed instrument was
  // established (synth code / stem separation / provider prompt / unknown).
  readiness    String    @default("pending") // pending | ready | rejected
  qualityState String    @default("unmeasured") // unmeasured | passed | failed | duplicate
  roleEvidence String    @default("unknown")
  rightsBasis  String    @default("unknown") // user-attested | code-generated | provider-generated | licensed | unknown
  contentHash  String?
  verifiedAt   DateTime? @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  usages    MaterialUsage[]

  @@unique([workspaceId, contentHash])
  @@index([workspaceId, genre, role])
  @@index([workspaceId, readiness, qualityState])
}

// An album anchored to ONE song's sound: the anchor's voice/flow/production
// defines the style, and every "next track" is generated INSIDE that lane.
model Album {
  id           String   @id @default(cuid())
  workspaceId  String
  title        String
  anchorSongId String?
  // Distilled style directive from the anchor (engine, genre, bpm, vocal, tags)
  // injected into every generation for this album.
  styleBrief   String?  @db.Text
  meta         Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  songs     Song[]

  @@index([workspaceId])
}

model Song {
  id               String     @id @default(cuid())
  workspaceId      String
  projectId        String
  title            String
  /// PER-SONG DISPLAY ARTIST (owner edit, 2026-07-20). The stage name shown on
  /// THIS song's card/player. Null falls back to the workspace Artist.stageName
  /// (via project.artist) — so renaming one song's singer never renames the
  /// workspace artist or any sibling song. Editing the singer name writes here.
  displayArtist    String?
  /// CATALOG TYPE (owner: "should I create my catalog based on type?"):
  /// song | instrumental | film_sound — stamped at creation so every door's
  /// output is findable and filterable.
  kind             String     @default("song")
  versionLabel     String? // "demo-1", "club-mix"
  albumId          String? // album this song belongs to (style-anchored)
  status           SongStatus @default(SKETCH)
  storyboard       Json? // arrangement timeline (intro/hook/verse/bridge/outro)
  // Rights spine — what makes a release bankable + payable.
  isrc             String?    @unique // recording code (CC-RRR-YY-DDDDD); null until registrant or distributor assignment
  upc              String?    @unique // release barcode; distributors assign the real one free
  splitSheet       Json? // [{name, role, share}] writer/producer splits summing to 100
  nativeReviewOk   Boolean    @default(false) // a native speaker signed off on Yoruba/Igbo/Hausa delivery
  releaseReady     Boolean    @default(false) // green-lit for distribution
  // QA quarantine (owner audit 2026-07-12): a song the Catalogue QA gate blocked
  // (empty/duplicate/contaminated) OR an operator pulled — hidden from the
  // catalogue, release, and public surfaces. Reversible; never hard-deleted so
  // the audit evidence survives. Reason kept for the Truth report.
  quarantined      Boolean    @default(false)
  quarantineReason String?
  // NEVER LOSE A SONG. Deleting a song is a soft delete: the row, its lyric, its
  // takes and its audio all survive, and the catalog's "Show ALL songs" view can
  // always bring it back. DELETE /songs/:id used to run a real tx.song.delete(),
  // which cascaded through LyricDraft/BeatAsset/Stem/VocalRender/Mix/Master/
  // Export/RightsReceipt/Release — one misclick, irreversible, no tombstone.
  // Same doctrine the `quarantined` flag above already states; the delete route
  // simply never honoured it.
  deletedAt        DateTime?  @db.Timestamptz(6)
  deletedReason    String?
  // A&R read — every produced song gets scored BEFORE it's considered done.
  hitScore         Int? // 0-100 from the Will-it-hit engine
  viralScore       Int? // 0-100
  hitRead          Json? // full prediction: strengths/risks/toMakeItBigger/tiktokMoment
  // WO-4 LISTEN-BACK — the studio LISTENS to every song it makes (measured, not
  // vibes; §1.6: compliance ≠ taste, so these live beside hitScore, never merged).
  laneScore        Int? // 0-100 measured lane compliance of the current audio
  measuredAnalysis Json? // MeasuredAnalysis of the current audio (provenance-tagged)
  laneGaps         Json? // { coverage, failedCritical[], topGaps[], drift, measuredAt }
  proofPack        Json? // per-song evidence bundle, persisted at green-light (lib/proof-pack.ts)
  // TRUE INSTRUMENTAL — the FINISHED song minus the voice (never the raw
  // pre-vocal beat): separated from the freshest master/mix, loudness-matched
  // back to it. Cleared whenever a new master is promoted — a changed song
  // must never serve yesterday's instrumental.
  instrumentalUrl  String? // 320k mp3 for the player/library (the WAV lives on the Stem row)
  acapellaUrl      String? // the isolated voice, same treatment
  instrumentalMeta Json? // { sourceUrl, sourceLufs, matchedLufs, engine, format, at }
  createdAt        DateTime   @default(now()) @db.Timestamptz(6)

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  hooks               HookCandidate[]
  lyric               LyricDraft?          @relation("SongPrimaryLyric")
  lyricId             String?              @unique
  beats               BeatAsset[]
  vocalRenders        VocalRender[]
  mixes               Mix[]
  masters             Master[]
  exports             Export[]
  rights              RightsReceipt[]
  releaseAttestations ReleaseAttestation[]
  taste               TasteScore[]
  materialUsages      MaterialUsage[]
  referenceUsages     ReferenceUsage[]
  shareLinks          ShareLink[]
  videoConcepts       VideoConcept[]       @relation("SongVideoConcept")
  release             Release?             @relation("ReleaseSong")
  album               Album?               @relation(fields: [albumId], references: [id], onDelete: SetNull)
  benchmarkPairs      BenchmarkPair[]

  @@index([projectId])
  @@index([albumId])
  // Catalog list is the hottest read (workspace scan ordered by recency).
  @@index([workspaceId, createdAt(sort: Desc)])
}

/// Global key/value settings — live operator toggles (e.g. turning off the
/// money-spending autonomous jobs from /admin without a redeploy).
model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

enum SongStatus {
  SKETCH
  DEMO
  FULL
  MIXED
  MASTERED
  EXPORTED // bundle built + downloaded — NOT distributed
  RELEASED // only after a signed distributor event confirms the release is live
}

// ===========================================================================
// Hooks + lyrics
// ===========================================================================

model HookCandidate {
  id        String   @id @default(cuid())
  projectId String
  songId    String?
  text      String   @db.Text
  language  String[] @default([])
  bpm       Int?
  meta      Json? // {melody_notes, syllable_pattern}
  score     Float?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  song        Song?        @relation(fields: [songId], references: [id], onDelete: SetNull)
  tasteScores TasteScore[]

  @@index([projectId])
  @@index([score(sort: Desc)])
}

model LyricDraft {
  id             String   @id @default(cuid())
  projectId      String
  songId         String?  @unique
  title          String?
  body           String   @db.Text // full structured lyric markdown
  structure      Json? // {sections:[{name:"verse1", lines:[...]}]}
  cleanVersion   String?  @db.Text
  explicit       Boolean  @default(false)
  // THE ARTIST'S OWN WORDS ARE LAW: from-lyrics/mumble-picked drafts set this;
  // the will-it-blow gate and make-it-bigger NEVER rewrite an artist-authored
  // lyric — they score it and stop ("doesn't follow my lyrics" root cause).
  artistAuthored Boolean  @default(false)
  languageMix    Json? // {pcm:0.6, yo:0.3, en:0.1}
  melody         Json? // melody spec per section: contour, syllable timing (drives sung vocals)
  translation    Json?
  // WRITING BRAIN craft object for the downstream Singing Brain:
  // {premise, hookCell, anchors: string[], sectionPurposes} — the semantic
  // skeleton (hookCell = the repeatable fragment inside the approved hook;
  // anchors = the emotional keywords that must survive any compression).
  craftJson      Json?
  // VERSION HISTORY — every prior take, newest-first: [{body,title,cleanVersion,at,label}].
  // Snapshotted BEFORE any rewrite (make-it-bigger / will-it-blow gate / manual edit)
  // so the ORIGINAL is never lost and the artist can revert to it or any prior take.
  versions       Json?
  approved       Boolean  @default(false)
  approvalNotes  String?
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  song        Song?        @relation("SongPrimaryLyric", fields: [songId], references: [id], onDelete: Cascade)
  tasteScores TasteScore[]

  @@index([projectId])
}

// ===========================================================================
// Audio (beats, stems, vocals, mixes, masters)
// ===========================================================================

model BeatAsset {
  id           String    @id @default(cuid())
  projectId    String
  songId       String?
  url          String
  format       String    @default("wav") // wav | mp3 | flac
  bpm          Int?
  keySignature String?
  duration     Float?
  provider     String
  assetKind    String    @default("instrumental") // instrumental | full_mix
  qualityState String    @default("unmeasured") // passed | weak | failed | unmeasured
  contentHash  String?
  verifiedAt   DateTime? @db.Timestamptz(6)
  meta         Json?
  approved     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  song            Song?            @relation(fields: [songId], references: [id], onDelete: Cascade)
  stems           Stem[]
  materialUsages  MaterialUsage[]
  referenceUsages ReferenceUsage[]

  @@index([projectId])
  @@index([songId, assetKind, qualityState, approved])
  @@index([projectId, contentHash])
}

model Stem {
  id           String    @id @default(cuid())
  beatId       String
  role         String // "drums","perc","bass","keys","guitar","pad","logdrum","fx","vocal","backing","adlib"
  url          String
  format       String    @default("wav")
  duration     Float?
  origin       String    @default("legacy") // legacy | provider | separation | native
  qualityState String    @default("unmeasured") // passed | weak | failed | unmeasured
  contentHash  String?
  verifiedAt   DateTime? @db.Timestamptz(6)
  lineage      Json? // immutable source + derivation receipt for these exact bytes
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)

  beat BeatAsset @relation(fields: [beatId], references: [id], onDelete: Cascade)

  @@index([beatId])
  @@index([beatId, qualityState, verifiedAt])
  @@index([beatId, contentHash])
}

model VocalRender {
  id                String    @id @default(cuid())
  projectId         String
  songId            String?
  voiceProfileId    String?
  role              String // "lead","double","ad-lib","harmony"
  url               String
  duration          Float?
  pitchCorrection   Json? // {strength:0.8, retune:0.2}
  effects           Json? // {reverb, delay, doubler, compressor presets}
  language          String?
  assetKind         String    @default("isolated_vocal") // isolated_vocal | spoken_guide | full_mix
  performanceSource String    @default("unknown") // artist_upload | artist_import | voice_conversion | score_synth | tts_guide | stem_separation | unknown
  qualityState      String    @default("unmeasured") // pending | passed | failed | unmeasured
  contentHash       String?
  verifiedAt        DateTime? @db.Timestamptz(6)
  alignment         Json? // measured lyric/phoneme alignment only; null means not measured
  meta              Json?
  approved          Boolean   @default(false)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  song         Song?         @relation(fields: [songId], references: [id], onDelete: Cascade)
  voiceProfile VoiceProfile? @relation(fields: [voiceProfileId], references: [id])

  @@index([projectId])
  @@index([songId, assetKind, qualityState, approved])
  @@index([projectId, contentHash])
}

model Mix {
  id           String    @id @default(cuid())
  projectId    String
  songId       String?
  preset       String // "radio","club","tiktok","youtube","console"
  url          String
  notes        String?
  settings     Json? // per-track mixer console state (faders/eq/comp/reverb)
  qualityState String    @default("unmeasured") // passed | failed | unmeasured
  contentHash  String?
  verifiedAt   DateTime? @db.Timestamptz(6)
  meta         Json?
  approved     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  song    Song?    @relation(fields: [songId], references: [id], onDelete: Cascade)
  masters Master[]

  @@index([projectId])
  @@index([songId, qualityState, approved])
}

model Master {
  id           String    @id @default(cuid())
  projectId    String
  songId       String?
  mixId        String?
  preset       String // "streaming_lufs_-14","club_-9","reels_-16"
  url          String
  loudness     Float?
  qualityState String    @default("unmeasured") // passed | failed | unmeasured
  contentHash  String?
  verifiedAt   DateTime? @db.Timestamptz(6)
  approved     Boolean   @default(false)
  // WO-6(a): measured QC of the MASTERED artifact — the release gate judges
  // this, never the pre-master take (what ships is what gets certified).
  meta         Json?
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  song    Song?   @relation(fields: [songId], references: [id], onDelete: Cascade)
  mix     Mix?    @relation(fields: [mixId], references: [id])

  @@index([projectId])
  @@index([songId, qualityState, approved])
  @@index([projectId, contentHash])
}

// ===========================================================================
// Learned sound references — the "listen & learn" library
// ===========================================================================

// A song the artist OWNS/licensed, deeply analyzed into a production recipe
// (drums, percussion, groove, bass, arrangement, flow). Accumulates per
// workspace/genre and is blended into generation so output learns the real
// sound. Scalar-only (no FK) to keep it decoupled. Legal: own/licensed audio.
model SoundReference {
  id            String   @id @default(cuid())
  workspaceId   String
  artistId      String?
  genre         String?
  sourceUrl     String
  title         String?
  recipe        Json // structured deep-analysis profile
  summary       String?  @db.Text // one text block ready for prompt injection
  analysisState String   @default("pending") // pending | inferred | measured | failed
  rightsBasis   String   @default("unknown") // user-attested | facts-only | self-generated | unknown
  contentHash   String?
  active        Boolean  @default(true) // false = curated out; usage evidence remains
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  usages ReferenceUsage[]

  @@unique([workspaceId, contentHash])
  @@index([workspaceId, genre])
  @@index([artistId])
  @@index([workspaceId, analysisState])
}

/// AFROREF — the rights-clean audio REFERENCE set (trainlegal wave): the
/// measuring stick FAD-CLAP compares training candidates against. Ingestion is
/// gated by afroRefEligibility (@afrohit/shared training-corpus.ts): ONLY
/// own-engine renders and consented user-original uploads — MiniMax/Suno/
/// ACE-step/Eleven renders are refused unconditionally (no operator override).
/// Scalar refs (no FK) like SoundReference, so the reference set survives
/// catalog churn and stays decoupled.
model AfroRefClip {
  id          String   @id @default(cuid())
  workspaceId String?
  songId      String?
  materialId  String?
  url         String
  genre       String
  language    String?
  /// TrainingOrigin recorded at ingest ('own-master' | 'user-original') — the
  /// gate's verdict, persisted so the set stays provably rights-clean.
  provenance  String
  /// Engine stamp checked by the gate (provable, not asserted).
  engine      String?
  contentHash String?
  addedAt     DateTime @default(now()) @db.Timestamptz(6)

  @@unique([contentHash])
  @@index([genre, language])
  @@index([songId])
}

// Queryable proof that a real material file was present in a rendered beat.
// Beat.meta keeps the human-readable receipt; this table is the auditable,
// aggregateable source of truth for "where was my loop used?".
model MaterialUsage {
  id            String   @id @default(cuid())
  workspaceId   String
  materialId    String
  providerJobId String
  beatId        String
  songId        String?
  role          String
  sourceBpm     Float?
  targetBpm     Float?
  stretchRatio  Float?
  gain          Float?
  pan           Float?
  sections      Json?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  material    MaterialAsset @relation(fields: [materialId], references: [id], onDelete: Restrict)
  providerJob ProviderJob   @relation(fields: [providerJobId], references: [id], onDelete: Cascade)
  beat        BeatAsset     @relation(fields: [beatId], references: [id], onDelete: Cascade)
  song        Song?         @relation(fields: [songId], references: [id], onDelete: SetNull)

  @@unique([providerJobId, materialId])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([materialId, createdAt(sort: Desc)])
  @@index([beatId])
}

// Queryable proof that a learned reference shaped a specific provider render.
// The influence field records the selected position and measurement state; it
// never stores source audio or copied musical expression.
model ReferenceUsage {
  id            String   @id @default(cuid())
  workspaceId   String
  referenceId   String
  providerJobId String
  beatId        String
  songId        String?
  genre         String
  position      Int
  pinned        Boolean  @default(false)
  influence     Json?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reference   SoundReference @relation(fields: [referenceId], references: [id], onDelete: Restrict)
  providerJob ProviderJob    @relation(fields: [providerJobId], references: [id], onDelete: Cascade)
  beat        BeatAsset      @relation(fields: [beatId], references: [id], onDelete: Cascade)
  song        Song?          @relation(fields: [songId], references: [id], onDelete: SetNull)

  @@unique([providerJobId, referenceId])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([referenceId, createdAt(sort: Desc)])
  @@index([beatId])
}

// The WORD BANK — thousands of authentic African/diaspora terms (Pidgin,
// Yoruba, Igbo, Hausa, Ghanaian Twi/Ga, Swahili + theme/drum/ad-lib/proverb
// banks) with meaning + register, searchable and sampled into generation so
// the writer has a WIDE vocabulary palette instead of repeating the same
// words. Seeded from a curated pack + expanded by research. GLOBAL by default
// (workspaceId null = shared library everyone draws from); a non-null
// workspaceId is a private/custom addition. Facts/vocabulary, never lyrics.
model LexiconEntry {
  id          String   @id @default(cuid())
  workspaceId String? // null = shared global library; set = private addition
  term        String
  language    String // pcm | yo | ig | ha | twi | sw | en | mixed | motif
  category    String // love | street | party | faith | proverb | dance | drums | places | slang | music | adlib | ...
  register    String? // casual | chant | poetic | vulgar | sacred | flex
  meaning     String?  @db.Text // plain-English gloss (so the writer uses it correctly)
  example     String?  @db.Text // one short original usage line (never a real lyric)
  tags        String[] // freeform: moods/genres it fits
  source      String   @default("seed") // seed | research | user | learned
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@unique([term, language, category])
  @@index([language, category])
  @@index([workspaceId])
}

// ===========================================================================
// Visuals (cover art + video)
// ===========================================================================

model ImageAsset {
  id           String    @id @default(cuid())
  projectId    String?
  brandKitId   String?
  kind         String // "cover","social","lyric_card","logo","promo"
  prompt       String?   @db.Text
  url          String
  width        Int?
  height       Int?
  provider     String
  qualityState String    @default("unmeasured") // passed | failed | unmeasured
  contentHash  String?
  verifiedAt   DateTime? @db.Timestamptz(6)
  approved     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)

  project  Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  brandKit BrandKit? @relation(fields: [brandKitId], references: [id])
  releases Release[] @relation("ReleaseCoverAsset")

  @@index([projectId])
  @@index([projectId, kind, qualityState, approved])
  @@index([projectId, contentHash])
}

model VideoConcept {
  id         String   @id @default(cuid())
  projectId  String
  // EVERY SONG GETS A VIDEO RECOMMENDATION — the piece that sits beside its
  // lyrics. This was project-scoped only, so a concept could not name the song
  // it was for: a project holds many songs, and the generator read the artist
  // lane and the project brief but never the song and never its words. Nullable
  // because older concepts were written before songs could be named, and a
  // project-level concept is still a legitimate thing to have.
  songId     String?
  title      String
  storyboard Json // [{shot:1, prompt:"...", duration_s:3, motion:"slow push-in"}]
  durationS  Int      @default(15)
  format     String   @default("vertical") // vertical | square | landscape
  notes      String?  @db.Text
  // ONE-CLICK FULL VIDEO (Wave 10): meta.autoAssemble = { requested, kind,
  // engineClass, ... } — stamped by POST /videos/render-all, single-fired by
  // the worker when every sequence gains a render (or honestly marked
  // 'incomplete' when terminal failures leave coverage short).
  meta       Json?
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  song    Song?         @relation("SongVideoConcept", fields: [songId], references: [id], onDelete: Cascade)
  renders VideoRender[]

  @@index([projectId])
  // Newest concept for a song is the hot read (the panel beside its lyrics).
  @@index([songId, createdAt(sort: Desc)])
}

model VideoRender {
  id        String   @id @default(cuid())
  projectId String
  conceptId String?
  url       String
  durationS Float?
  provider  String
  meta      Json?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  concept VideoConcept? @relation(fields: [conceptId], references: [id])

  @@index([projectId])
}

// ===========================================================================
// Taste, Approvals, Rights
// ===========================================================================

model TasteScore {
  id             String   @id @default(cuid())
  songId         String?
  hookId         String?
  lyricId        String?
  dimensions     Json // map of {hookMemorability:8.3, danceability:7.9, ...}
  overall        Float
  notes          String?  @db.Text
  similarityRisk Float? // 0-1
  tooAiRisk      Float? // 0-1
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  // Cascade: taste rows are meaningless without their subject — no orphans.
  song  Song?          @relation(fields: [songId], references: [id], onDelete: Cascade)
  hook  HookCandidate? @relation(fields: [hookId], references: [id], onDelete: Cascade)
  lyric LyricDraft?    @relation(fields: [lyricId], references: [id], onDelete: Cascade)

  @@index([songId])
  @@index([hookId])
  @@index([lyricId])
}

model Approval {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String
  userId      String
  gate        String // brief|hook|lyrics|beat|voice|mix|rights|release
  decision    String // approved | rejected | changes_requested
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@index([projectId])
}

// Native-language / quality review queue. Created automatically when the
// lyric generator flags uncertain Yoruba/Igbo/Hausa/Pidgin lines.
model ReviewTask {
  id          String    @id @default(cuid())
  workspaceId String
  projectId   String?
  lyricId     String?
  kind        String // "native_language" | "quality" | "rights"
  language    String? // primary language needing review
  status      String    @default("open") // open | approved | rejected
  items       Json // [{ref:"yo:line 4 of verse 2", text?, reason?}]
  notes       String?   @db.Text
  resolvedBy  String? // userId
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  resolvedAt  DateTime? @db.Timestamptz(6)

  @@index([workspaceId, status])
}

model RightsReceipt {
  id                String   @id @default(cuid())
  workspaceId       String
  projectId         String
  songId            String
  voiceConsentId    String?
  providers         Json // [{kind:"music", provider:"eleven", model:"music-v1", commercial_terms_url:"..."}]
  prompts           Json // captured prompts/inputs
  canonicalPayload  Json? // complete recursively-canonical evidence object hashed by hash
  samples           Json? // [{source:"upload://...", licensed:true}]
  approvals         Json // snapshot of approval IDs at receipt creation
  humanContribution String?  @db.Text // describing what the human did
  aiDisclosure      Json? // {distro: "DistroKid disclosure: yes", credits:{lyrics:"AI-assisted, human-edited"}}
  hash              String // sha256 over canonical JSON of the receipt
  createdAt         DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  song      Song      @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ReleaseAttestation {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String
  songId      String
  kind        String // split_sheet | native_language
  payload     Json
  hash        String
  attestedBy  String
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  song      Song      @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([songId, kind, createdAt(sort: Desc)])
}

// ===========================================================================
// Exports + Releases
// ===========================================================================

model Export {
  id                String    @id @default(cuid())
  projectId         String
  songId            String
  bundle            Json // release package summary; never a substitute for archiveUrl
  archiveUrl        String?
  contentHash       String?
  sourceFingerprint String?
  sizeBytes         Int?
  qualityState      String    @default("pending") // ready | failed | pending | legacy_reference_only
  manifest          Json?
  verifiedAt        DateTime? @db.Timestamptz(6)
  receiptId         String?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  song    Song    @relation(fields: [songId], references: [id], onDelete: Cascade)
  releases Release[] @relation("ReleaseExport")

  @@unique([songId, sourceFingerprint])
  @@index([projectId])
  @@index([songId, qualityState])
}

model Release {
  id                   String    @id @default(cuid())
  workspaceId          String
  projectId            String?
  artistId             String
  songId               String    @unique
  revision             Int       @default(0)
  title                String?
  artistName           String?
  genre                String?
  isrc                 String?   @unique
  upc                  String?   @unique
  audioAssetId         String?
  audioAssetKind       String?
  audioUrl             String?
  coverAssetId         String?
  coverUrl             String?
  exportId             String?
  archiveUrl           String?
  artifactFingerprint  String?
  evidenceHash         String?
  releaseDate          DateTime? @db.Timestamptz(6)
  submittedAt          DateTime? @db.Timestamptz(6)
  liveAt               DateTime? @db.Timestamptz(6)
  distributor          String?
  externalId           String?   @unique
  status               String    @default("draft")
  distributionStatusAt DateTime? @db.Timestamptz(6)
  channels             Json? // {spotify:"link", apple:"link", youtube:"link"}
  createdAt            DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  workspace  Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  artist     Artist              @relation(fields: [artistId], references: [id], onDelete: Cascade)
  song       Song                @relation("ReleaseSong", fields: [songId], references: [id], onDelete: Cascade)
  coverAsset ImageAsset?         @relation("ReleaseCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  export     Export?             @relation("ReleaseExport", fields: [exportId], references: [id], onDelete: SetNull)
  events     DistributionEvent[]
  revisions  ReleaseRevision[]

  @@index([workspaceId, status])
  @@index([projectId])
  @@index([coverAssetId])
  @@index([exportId])
}

/// Append-only package and distributor-state snapshots. Database triggers own
/// inserts so webhook transitions cannot accidentally skip release history.
model ReleaseRevision {
  id          String   @id
  releaseId   String
  workspaceId String
  projectId   String?
  songId      String
  revision    Int
  status      String
  audioUrl    String?
  coverUrl    String?
  archiveUrl  String?
  snapshot    Json
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([releaseId, revision])
  @@index([releaseId, createdAt(sort: Desc)])
  @@index([workspaceId, status])
}

/// Atomic namespaces for registrant-assigned ISRC and GS1 UPC values.
model ReleaseIdentifierSequence {
  namespace String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

/// Audit trail for identifiers displaced while legacy duplicates are reconciled
/// before global uniqueness is enforced.
model ReleaseIdentifierConflict {
  id               BigInt   @id @default(autoincrement())
  entityType       String
  entityId         String
  field            String
  value            String
  retainedEntityId String
  createdAt        DateTime @default(now()) @db.Timestamptz(6)

  @@index([entityType, field, value])
}

/// Storage refs captured by delete triggers before their owning rows disappear.
/// The cleanup worker consumes these only after checking all surviving owners.
model AssetDeletionCandidate {
  id          BigInt   @id @default(autoincrement())
  workspaceId String
  projectId   String?
  songId      String?
  ref         String
  kind        String
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([workspaceId, songId])
  @@index([workspaceId, projectId])
}

model DistributionEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  releaseId   String
  externalId  String
  status      String
  payloadHash String
  applied     Boolean  @default(false)
  occurredAt  DateTime @db.Timestamptz(6)
  receivedAt  DateTime @default(now()) @db.Timestamptz(6)

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId, occurredAt])
  @@index([externalId, receivedAt])
}

/// LISTENING BENCHMARK — the ear-vs-machine ground truth. Each row is a rendered
/// track (ours or a reference) rated 1–5 by a human, tagged with the machine's
/// lane score, so per-genre we can see whether "lane 87" matches the ear and
/// whether we actually beat a reference in a blind A/B. This is the app's real
/// improvement loop (no more trusting a score the ear disagrees with).
model BenchmarkRating {
  id          String   @id @default(cuid())
  workspaceId String
  genre       String
  source      String   @default("afrohit") // afrohit | reference | suno
  songId      String?
  audioUrl    String
  engine      String? // which engine rendered it (minimax/own/suno...)
  laneScore   Int? // the machine's measured lane compliance at render time
  humanRating Int // 1..5 the ear
  blindLabel  String? // 'A'/'B' when captured via a blind A/B
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, genre])
}

/// Immutable, blind comparison between one certified AfroHit render and one
/// rights-attested competitor render. Asset references and hashes are frozen
/// when the pair is created so later song edits cannot rewrite the evidence.
model BenchmarkPair {
  id                   String    @id @default(cuid())
  workspaceId          String
  createdById          String
  songId               String
  genre                String
  competitor           String    @default("suno")
  afrohitAssetRef      String
  afrohitContentHash   String
  referenceAssetRef    String
  referenceContentHash String
  referenceSizeBytes   Int
  referenceFormat      String
  rightsBasis          String
  rightsAttestation    Json
  seed                 String
  status               String    @default("open")
  createdAt            DateTime  @default(now()) @db.Timestamptz(6)
  closedAt             DateTime? @db.Timestamptz(6)

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User                @relation("BenchmarkPairCreator", fields: [createdById], references: [id], onDelete: Cascade)
  song      Song                @relation(fields: [songId], references: [id], onDelete: Cascade)
  judgments BenchmarkJudgment[]

  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([competitor, genre])
}

/// One independent listener verdict. The API stores normalized source results
/// only after mapping the listener's randomized A/B side assignment.
model BenchmarkJudgment {
  id               String   @id @default(cuid())
  workspaceId      String
  pairId           String
  userId           String
  winner           String
  afrohitScores    Json
  competitorScores Json
  confidence       Int
  note             String?  @db.Text
  createdAt        DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pair      BenchmarkPair @relation(fields: [pairId], references: [id], onDelete: Cascade)
  user      User          @relation("BenchmarkJudge", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pairId, userId])
  @@index([workspaceId, createdAt(sort: Desc)])
}

// ===========================================================================
// Sharing + PostGIS heatmap
// ===========================================================================

model ShareLink {
  id          String   @id @default(cuid())
  workspaceId String
  songId      String
  code        String   @unique // short slug for URL: afro.hi/<code>
  targetUrl   String // canonical landing (or distributor link)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  song      Song         @relation(fields: [songId], references: [id], onDelete: Cascade)
  events    ShareEvent[]

  @@index([songId])
}

model ShareEvent {
  id             String   @id @default(cuid())
  workspaceId    String
  shareLinkId    String
  songId         String?
  eventType      String // "click","play","download","share","conversion"
  sourcePlatform String? // "tiktok","instagram","whatsapp","x","direct"
  city           String?
  region         String?
  country        String?
  countryCode    String?  @db.Char(2)
  // Plain coordinates (no PostGIS). Heatmap centroids come from AVG(lat/lng).
  lat            Float?
  lng            Float?
  ipHash         String? // hashed IP (never raw)
  userAgent      String?
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  shareLink ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)

  @@index([shareLinkId])
  @@index([country, createdAt])
}

// ===========================================================================
// Vector memory (Artist DNA / production memory)
// ===========================================================================

model ArtistMemoryChunk {
  id          String   @id @default(cuid())
  workspaceId String
  artistId    String
  kind        String // "slang","phrase","reference","note","rejected","approved","melody_idea"
  content     String   @db.Text
  language    String?
  // JSON number[] embedding used by hybrid semantic/lexical retrieval. Keeping
  // it as JSON avoids requiring pgvector while the memory corpus stays bounded.
  embedding   Json?
  sourceUrl   String?
  meta        Json?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  artist    Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
  @@index([workspaceId, artistId, kind, createdAt])
}

// ===========================================================================
// Provider jobs (BullMQ runs in Redis; we mirror state here for audit + UI)
// ===========================================================================

model ProviderJob {
  id             String    @id @default(cuid())
  workspaceId    String
  projectId      String?
  kind           String // "music","voice","mix","master","image","video","export","embed","rights"
  provider       String
  externalId     String?
  status         JobStatus @default(QUEUED)
  inputJson      Json
  outputJson     Json?
  errorJson      Json?
  cost           Decimal?  @db.Decimal(12, 6) // estimated cost in USD
  creditsCents   Int       @default(0)
  idempotencyKey String?
  chargeLedgerId String?   @unique
  startedAt      DateTime? @db.Timestamptz(6)
  finishedAt     DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project         Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  chargeLedger    CreditLedger?    @relation("ProviderJobCharge", fields: [chargeLedgerId], references: [id], onDelete: SetNull)
  outbox          JobOutbox?
  materialUsages  MaterialUsage[]
  referenceUsages ReferenceUsage[]

  @@unique([workspaceId, kind, idempotencyKey])
  @@index([workspaceId])
  @@index([status])
  // Jobs dashboard: workspace scan ordered by recency.
  @@index([workspaceId, createdAt(sort: Desc)])
}

// ===========================================================================
// Job events — append-only progress/partial channel for a ProviderJob.
// The model itself only exposes terminal outputJson (written once); this log is
// how the UI learns real pipeline state BETWEEN queued and terminal (kills the
// fake spinner) and how a playable bed URL is surfaced MINUTES before a sung
// render finishes (bed-first streaming). Deliberately decoupled — NO foreign
// key — so emitJobEvent is fail-soft and can never throw into a render. `seq`
// is a global autoincrement, so a client polls the tail with ?since=<seq>.
// ===========================================================================
model JobEvent {
  seq         Int      @id @default(autoincrement())
  jobId       String
  phase       String
  payloadJson Json?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  // Tail read: newest-for-job + since-cursor, both served by this one index.
  @@index([jobId, seq])
}

model JobOutbox {
  id            String       @id @default(cuid())
  workspaceId   String
  providerJobId String       @unique
  queueName     String
  jobName       String
  payload       Json
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  nextAttemptAt DateTime     @default(now()) @db.Timestamptz(6)
  dispatchedAt  DateTime?    @db.Timestamptz(6)
  lastError     String?
  createdAt     DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @db.Timestamptz(6)

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  providerJob ProviderJob @relation(fields: [providerJobId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([workspaceId])
}

enum OutboxStatus {
  PENDING
  DISPATCHED
  FAILED
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

// ===========================================================================
// Chat (Studio Chat persistence + tool-call audit)
// ===========================================================================

model ChatThread {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  projectId   String?
  title       String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])
  project   Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages  ChatMessage[]

  @@index([workspaceId, userId])
}

model ChatMessage {
  id           String   @id @default(cuid())
  threadId     String
  role         String // "user","assistant","tool","system"
  content      String   @db.Text
  toolName     String?
  toolInput    Json?
  toolOutput   Json?
  artifactRefs Json? // [{kind:"hook", id:"..."}, ...]
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  // Every chat load reads thread history in order — cover filter + sort.
  @@index([threadId, createdAt])
}

// ===========================================================================
// Billing (credit ledger + PayPal events)
// ===========================================================================

model CreditLedger {
  id             String   @id @default(cuid())
  workspaceId    String
  delta          Int // +/- credits in 1/100 cents
  reason         String // "topup_paypal","job_music","job_voice","refund","grant"
  creditKey      String?
  units          Int      @default(1)
  planUnits      Int      @default(1)
  refTable       String? // e.g. "ProviderJob"
  refId          String?
  paypalEventId  String?  @unique // dedupe key from PayPal webhook event id
  idempotencyKey String?
  reversalOfId   String?  @unique
  meta           Json?
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  workspace               Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chargedJob              ProviderJob?        @relation("ProviderJobCharge")
  reversalOf              CreditLedger?       @relation("CreditReversal", fields: [reversalOfId], references: [id], onDelete: SetNull)
  reversal                CreditLedger?       @relation("CreditReversal")
  billingEntitlementGrant BillingEntitlement? @relation("BillingEntitlementGrant")
  billingAdjustment       BillingAdjustment?  @relation("BillingAdjustmentLedger")

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, creditKey, createdAt])
}

model BillingIntent {
  id                   String              @id @default(cuid())
  workspaceId          String
  kind                 BillingIntentKind
  status               BillingIntentStatus @default(CREATED)
  plan                 Plan?
  packKey              String?
  amountUsd            Decimal?            @db.Decimal(12, 2)
  currency             String?             @db.Char(3)
  creditsCents         Int?
  paypalOrderId        String?             @unique
  paypalSubscriptionId String?             @unique
  approvalUrl          String?
  idempotencyKey       String
  completedAt          DateTime?           @db.Timestamptz(6)
  createdAt            DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime            @updatedAt @db.Timestamptz(6)

  workspace            Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscriptionIdentity BillingSubscription?
  entitlements         BillingEntitlement[]

  @@unique([workspaceId, kind, idempotencyKey])
  @@index([workspaceId, createdAt(sort: Desc)])
}

enum BillingIntentKind {
  CREDIT_PACK
  SUBSCRIPTION
}

enum BillingIntentStatus {
  CREATED
  PENDING_APPROVAL
  APPROVED
  COMPLETED
  CANCELED
  FAILED
}

enum BillingSubscriptionStatus {
  PENDING
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELED
}

model BillingSubscription {
  id                   String                    @id @default(cuid())
  workspaceId          String
  billingIntentId      String                    @unique
  paypalSubscriptionId String                    @unique
  plan                 Plan
  status               BillingSubscriptionStatus @default(PENDING)
  statusEventAt        DateTime?                 @db.Timestamptz(6)
  activatedAt          DateTime?                 @db.Timestamptz(6)
  endedAt              DateTime?                 @db.Timestamptz(6)
  createdAt            DateTime                  @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime                  @updatedAt @db.Timestamptz(6)

  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  billingIntent BillingIntent        @relation(fields: [billingIntentId], references: [id], onDelete: Cascade)
  entitlements  BillingEntitlement[]

  @@index([workspaceId, status, statusEventAt(sort: Desc)])
}

enum BillingEntitlementKind {
  CREDIT_PACK
  SUBSCRIPTION_CYCLE
}

model BillingEntitlement {
  id                  String                 @id @default(cuid())
  workspaceId         String
  billingIntentId     String?
  subscriptionId      String?
  kind                BillingEntitlementKind
  paypalTransactionId String                 @unique
  grossAmountCents    Int?
  currency            String                 @default("USD") @db.Char(3)
  creditsGranted      Int
  grantLedgerId       String                 @unique
  occurredAt          DateTime               @db.Timestamptz(6)
  createdAt           DateTime               @default(now()) @db.Timestamptz(6)

  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  billingIntent BillingIntent?       @relation(fields: [billingIntentId], references: [id], onDelete: SetNull)
  subscription  BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  grantLedger   CreditLedger         @relation("BillingEntitlementGrant", fields: [grantLedgerId], references: [id], onDelete: Cascade)
  adjustments   BillingAdjustment[]

  @@index([workspaceId, occurredAt(sort: Desc)])
  @@index([subscriptionId, occurredAt(sort: Desc)])
}

enum BillingAdjustmentKind {
  REFUND
  REVERSAL
  DISPUTE
}

model BillingAdjustment {
  id            String                @id @default(cuid())
  entitlementId String
  paypalEventId String
  kind          BillingAdjustmentKind
  sourceId      String
  sourceStatus  String
  amountCents   Int?
  creditsAtRisk Int
  ledgerDelta   Int                   @default(0)
  ledgerId      String?               @unique
  occurredAt    DateTime              @db.Timestamptz(6)
  createdAt     DateTime              @default(now()) @db.Timestamptz(6)

  entitlement BillingEntitlement @relation(fields: [entitlementId], references: [id], onDelete: Cascade)
  ledger      CreditLedger?      @relation("BillingAdjustmentLedger", fields: [ledgerId], references: [id], onDelete: SetNull)

  @@unique([paypalEventId, entitlementId])
  @@index([entitlementId, kind, sourceId, occurredAt(sort: Desc)])
}

model BillingEvent {
  id            String    @id @default(cuid())
  paypalEventId String    @unique
  workspaceId   String?
  eventType     String
  resourceId    String?
  status        String    @default("processing")
  errorCode     String?
  attempts      Int       @default(1)
  processingAt  DateTime? @db.Timestamptz(6)
  processedAt   DateTime? @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([status, createdAt])
}

// ===========================================================================
// Analytics (lightweight event stream — heavy stuff goes to PostHog)
// ===========================================================================

model AnalyticsEvent {
  id          String   @id @default(cuid())
  workspaceId String?
  userId      String?
  name        String
  properties  Json?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([name])
}
