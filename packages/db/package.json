{
  "name": "@afrohit/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
  },
  "files": ["dist", "prisma"],
  "scripts": {
    "generate": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.json",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:safe": "node scripts/migrate-deploy.mjs",
    "push": "prisma db push",
    "push:deploy": "prisma db push --skip-generate",
    "studio": "prisma studio",
    "seed": "tsx src/seed.ts",
    "lexicon:seed": "node seed/lexicon-seed.mjs",
    "lexicon:dump": "node seed/dump-lexicon.mjs",
    "lexicon:corpus": "node seed/dump-lexicon.mjs && node seed/build-corpus.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@afrohit/shared": "workspace:*",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  }
}
