{
  "name": "@afrohit/shared",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server-url-safety": {
      "types": "./dist/server-url-safety.d.ts",
      "default": "./dist/server-url-safety.js"
    },
    "./video-prompt-hash": {
      "types": "./dist/video-prompt-hash.d.ts",
      "default": "./dist/video-prompt-hash.js"
    }
  },
  "typesVersions": {
    "*": {
      "server-url-safety": [
        "dist/server-url-safety.d.ts"
      ],
      "video-prompt-hash": [
        "dist/video-prompt-hash.d.ts"
      ],
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "undici": "^6.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
