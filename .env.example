# ============================================================================
# AfroHit Studio — environment template
# Copy to .env (root) for local dev, and per-app .env in apps/{web,api,worker}
# ============================================================================

NODE_ENV=development
LOG_LEVEL=info
# Number of reverse-proxy hops trusted for client IPs in production.
TRUST_PROXY_HOPS=1

# ----- Public URLs -------------------------------------------------
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
WORKER_INTERNAL_URL=http://localhost:4100

# ----- Datastores --------------------------------------------------
# Plain PostgreSQL 16; no extensions are required.
DATABASE_URL=postgresql://afrohit:afrohit@localhost:5432/afrohit?schema=public

# Redis for BullMQ + cache
REDIS_URL=redis://localhost:6379

# ----- Object Storage (Railway Object Storage / Cloudflare R2 / S3) -
# Cloudflare R2? You can ALSO just set R2_S3_API_URL / R2_ACCOUNT_ID / R2_BUCKET /
# R2_PUBLIC_URL / R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY — the app reads both
# schemes (S3_* wins when both are set).
S3_ENDPOINT=https://your-bucket.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=afrohit-studio
# Production will not boot until the bucket is private and this is explicitly 1.
STORAGE_PRIVATE_CONFIRMED=0
S3_ACCESS_KEY=
S3_SECRET_KEY=
# New assets stay private and use stable s3:// references. Keep a public base
# only while migrating legacy rows; it is not used for new uploads.
# S3_PUBLIC_BASE_URL=https://cdn.afrohit.studio

# ----- Auth --------------------------------------------------------
# Production must use jwt. Internal mode always refuses to boot in production.
AUTH_MODE=jwt
JWT_SECRET=
IP_HASH_SECRET=
# Use "none" only for a truly cross-site web/API deployment over HTTPS.
SESSION_COOKIE_SAMESITE=lax
# Public account creation is closed by default in production.
ALLOW_PUBLIC_SIGNUP=0
INTERNAL_WORKSPACE_SLUG=studio
INTERNAL_OWNER_EMAIL=owner@afrohit.local

# ----- Billing (PayPal) -------------------------------------------
# Mode: "sandbox" for dev, "live" for production. The PayPal REST hostname
# is derived from this — no need to set it separately.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Webhook ID is created in the PayPal dashboard under Apps → My App → Webhooks.
# We need it to verify incoming webhook signatures.
PAYPAL_WEBHOOK_ID=
# Billing Plan IDs — create one Catalog Product + four Plans in PayPal once,
# then paste the Plan IDs (start with P-...) here.
PAYPAL_PLAN_STARTER=
PAYPAL_PLAN_CREATOR=
PAYPAL_PLAN_PRO=
PAYPAL_PLAN_STUDIO=
# Credit packs are just one-off Orders priced server-side; no product IDs needed.

# ----- AI Providers ------------------------------------------------
# OpenAI — the "writer": drafts hooks/lyrics for breadth, plus STT/TTS/images.
OPENAI_API_KEY=sk-xxx
# The flagship GPT — used when a call explicitly asks for the OpenAI brain
# (e.g. /admin → Writer A/B). Set gpt-5.6-sol ($5/$30 per M) to bench the
# newest GPT vs Claude; gpt-5.6-terra ($2.50/$15) is the Sonnet-priced tier.
OPENAI_TEXT_MODEL=gpt-4o
# GPT-5.x reasoning dials (ignored by non-reasoning models like gpt-4o):
# effort none|low|medium|high|xhigh|max (default medium — reasoning tokens
# bill as OUTPUT, so high+ costs real money per call), plus cap headroom so
# the thinking can't starve the visible lyric (default 12000 tokens).
# OPENAI_REASONING_EFFORT=medium
# OPENAI_REASONING_HEADROOM=12000
OPENAI_DRAFT_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_IMAGE_MODEL=gpt-image-1

# Anthropic — THE BRAIN (Claude-first for all creative work): hooks, lyrics,
# briefs, A&R critique, taste scoring, Studio Chat. If unset, the system falls
# back to GPT-only. Set on api + worker.
#
# MODEL — claude-sonnet-5 BY OWNER DIRECTIVE (2026-07-10). Fable 5 burned a
# $20 top-up in <2 songs: Mythos-class pricing PLUS its thinking tokens count
# against max_tokens, so the truncation guard re-ran big calls at double cap —
# many calls billed TWICE at flagship rates. Sonnet ran the same studio at
# $6-16/day. NEVER set claude-fable-5 here except for a deliberate, budgeted
# one-off pass. A Railway value OVERRIDES the code default — keep it sonnet or
# delete it. The refusal fallback (rare) retries once on Opus 4.8.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_FALLBACK_MODEL=claude-opus-4-8

# Tavily — live web trend research ("what's hot in Afrobeats right now").
# Optional; without it the research_trends tool is skipped. Set on api + worker.
TAVILY_API_KEY=

# Music generation providers
ELEVEN_API_KEY=
# ELEVEN_MUSIC_MODEL=music_v2
# Customer routing is OFF until the account/plan, required co-branding, input
# restrictions, and commercial use are approved against the current Music API
# Terms. First-party evaluation remains available without this flag.
ELEVEN_MUSIC_CUSTOMER_ROUTE_APPROVED=0

# Optional Suno-compatible gateway for first-party releases only. SUNO_API_BASE
# defaults to the current gateway contract; this is not represented as an
# official Suno developer API. Set the key on the worker that performs renders.
SUNO_API_KEY=
# SUNO_MODEL=V5_5
# SUNO_API_BASE=https://api.sunoapi.org
# Required by the gateway. Point it at this API's no-op callback; the worker
# still polls authenticated task status as the source of truth.
# SUNO_CALLBACK_URL=https://api.your-domain.com/webhooks/suno
# Force ONE engine for every vocal-song path (create page, chat, regenerate),
# overriding automatic connected-engine selection. Leave unset unless testing a
# specific full-song engine: suno | eleven | ace_step | minimax.
# SONG_ENGINE=suno

# WO-5 PROGRESSIVE BEST-OF-N — DRAFT default is 1 (cheapest first listen; the ear
# measures it regardless). Escalation is demand-driven: each "make it bigger" adds
# exactly ONE new take, compared against stored measurements — best-of-N is
# accumulated over time, never rendered blind upfront. Premium/Hit-Maker flows
# pass candidates:2 per request. Raise this only to change the DRAFT default.
BEST_OF_N=1

# ---- LANE PIPELINE cost gates (all DEFAULT-ON now for the testing phase) ----
# The ear/lane machinery. Each is ON unless set to 0. LANE_ASSESS: measure every
# render's lane + steer regens. DSP_STEMS: Demucs-stem-aware detection (the log drum
# lives in the bass stem). FILL_OVERLAY: lay drum fills into section transitions.
LANE_ASSESS=1
DSP_STEMS=1
FILL_OVERLAY=1
# NOTE: there is NO LOGDRUM_CALIBRATED flag. The log drum is a TRUTH gate — it
# calibrates via py/fixtures/logdrum_calibration.json (written by eval-ear.ts when the
# 9-track acceptance passes), never by a human toggle.
# Generate this secret outside Git and keep the same 32+ byte value on every worker.
LOGDRUM_CALIBRATION_SIGNING_KEY=

# Connected music provider. Replicate routes full songs and full instrumentals
# to MiniMax; MusicGen is retained only for explicit short-loop forging. Eleven
# uses the verified Music v2 compose API. Unknown/unconfigured values fail closed.
MUSIC_PROVIDER=replicate
# INSTRUMENTAL_ENGINE=minimax  # optional explicit route override
VOICE_PROVIDER=eleven         # needs ELEVENLABS key + validation on YOUR account; stub hard-fails in prod
VIDEO_PROVIDER=veo            # veo | sora; production rejects stub or missing providers
IMAGE_PROVIDER=openai         # validated (gpt-image-1 → dall-e-3 fallback); stub hard-fails in prod

# Video — Google Veo via Vertex AI
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GCP_SERVICE_ACCOUNT_JSON_B64=
VEO_MODEL=veo-3.1-fast-generate-001
VEO_RESOLUTION=720p

# ----- Video ENGINE TIERS (Wave 4) -------------------------------
# Class-tagged renders (draft|standard|flagship) route through Replicate
# using REPLICATE_API_TOKEN (or the workspace-pasted key). Defaults:
#   draft    = wavespeedai/wan-2.1-t2v-480p (+ ...-i2v-480p for keyframes)
#   standard = minimax/video-01  (Hailuo — the DEFAULT class)
#   flagship = kwaivgi/kling-v2.1
# Override per class; set an *_I2V_MODEL to "" to declare the engine cannot
# do image-to-video (keyframe renders then fail closed, honestly).
# REPLICATE_VIDEO_DRAFT_MODEL=
# REPLICATE_VIDEO_DRAFT_I2V_MODEL=
# REPLICATE_VIDEO_DRAFT_VERSION=          # optional version pin
# REPLICATE_VIDEO_STANDARD_MODEL=
# REPLICATE_VIDEO_STANDARD_I2V_MODEL=
# REPLICATE_VIDEO_FLAGSHIP_MODEL=
# REPLICATE_VIDEO_FLAGSHIP_I2V_MODEL=
# Honest cost evidence (no invented estimates): set per-engine USD/second
# rates and the worker records them; otherwise cost stays "unknown".
# WAN_COST_USD_PER_SECOND=
# HAILUO_COST_USD_PER_SECOND=
# KLING_COST_USD_PER_SECOND=

# ----- Artist LIKENESS (own-face LoRA; Wave 4) --------------------
# Consent-gated Flux LoRA training of the artist's OWN face. Default OFF —
# flip to 1 only when a Replicate token + destination are set. Provider cost
# is roughly $2-5 per training run; keyframes ~$0.02-0.04 each.
LIKENESS_TRAINING_ENABLED=0
# LIKENESS_TRAINER_MODEL=replicate/fast-flux-trainer   # or ostris/flux-dev-lora-trainer
# LIKENESS_TRAINER_VERSION=       # optional version pin
# LIKENESS_LORA_DESTINATION=      # "user/model" in YOUR Replicate account (kept private)
# REPLICATE_USERNAME=             # fallback: auto-derives afrohit-likeness-<artist> destinations
# LIKENESS_POLL_MAX_ATTEMPTS=120
# LIKENESS_POLL_DELAY_MS=15000

# Video — OpenAI Sora
OPENAI_VIDEO_MODEL=sora-2
# Provider pricing changes. Pin the current contracted per-second rate instead
# of hardcoding a stale price. Acceptance fails when cost evidence is absent.
VEO_COST_USD_PER_SECOND=
SORA_COST_USD_PER_SECOND=
# VIDEO_COST_USD_PER_SECOND=   # optional selected-route fallback
VIDEO_TOOL_TIMEOUT_MS=180000   # hard timeout for ffprobe and full-frame decode

# ----- Internal --------------------------------------------------
INTERNAL_API_SECRET=replace-with-at-least-32-random-bytes
# Generate once with: openssl rand -base64 32
ENCRYPTION_KEY=

# ----- Email (Resend) — transactional: welcome, job-done, receipts, drops --
RESEND_API_KEY=
EMAIL_FROM=AfroHit Studio <noreply@afrohit.studio>

# ----- Admin — comma-separated operator emails for /api/v1/admin/* ---------
ADMIN_EMAILS=

# ----- Observability ---------------------------------------------
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ----- Music brain (Replicate) — THE key that powers beats/vocals/stems/listen.
# Paste in-app (Settings → Music engine) or set here; the WORKER needs it too.
REPLICATE_API_TOKEN=
# Optional model overrides (defaults resolved at runtime)
# REPLICATE_MUSIC_MODEL= / REPLICATE_MUSIC_VERSION=
# REPLICATE_SONG_MODEL= / REPLICATE_SONG_VERSION=
# LIP-SYNC on music videos (kwaivgi/kling-lip-sync, uses REPLICATE_API_TOKEN).
# ON by default now (owner order: lip sync on every video). Real spend ~$1-2 per
# full video; set LIPSYNC_ENABLED=0 to disable. Needs a class engine (character-
# sheet face on performance scenes) for a mouth to sync; b-roll scenes keep their
# original clip. Optionally pin REPLICATE_LIPSYNC_VERSION for run-to-run stability.
# LIPSYNC_ENABLED=0
# REPLICATE_LIPSYNC_VERSION=
# REPLICATE_MINIMAX_MODEL= / REPLICATE_MINIMAX_VERSION=
# REPLICATE_DEMUCS_MODEL= / REPLICATE_DEMUCS_VERSION=
# REPLICATE_TRANSCRIBE_MODEL= / REPLICATE_TRANSCRIBE_VERSION=
# REPLICATE_AUDIO_UNDERSTAND_MODEL= / REPLICATE_AUDIO_UNDERSTAND_VERSION=

# ----- VOICE TRAINING (own-voice singing model, Replicate trainings API) ----
# The artist trains a singing-voice model on HIS OWN recordings — his data,
# his rights. Trained weights land in YOUR Replicate account (the destination
# model below) — keep that destination model PRIVATE. Consent-gated: training
# requires a signed VoiceConsent row. Unset model/version → the API answers an
# honest 501 (voice_training_not_configured) instead of pretending.
#
# Picking a trainer: choose an RVC-family voice trainer of your choice on
# Replicate and pin its exact slug + version hash here — the code never
# guesses either. The base RVC lineage is MIT-licensed; a model trained
# exclusively on the artist's own recordings is the artist's.
#
# Dataset: ONE zip of clean SOLO vocals (wav/mp3), roughly 10-20 minutes total,
# no backing music/reverb — dry stems train best. Host it in app storage
# External dataset URLs are rejected unless ALLOW_EXTERNAL_VOICE_DATASET=1.
# ALLOW_EXTERNAL_VOICE_DATASET=0
# VOICE_TRAINER_MODEL=            # "owner/name" of the trainer on Replicate
# VOICE_TRAINER_VERSION=          # the trainer's version hash
# VOICE_TRAINER_DATASET_KEY=dataset_zip   # the trainer's input field for the zip (check its schema)
# VOICE_TRAINER_EXTRA_INPUT=      # optional JSON merged into the training input, e.g. {"epochs":80}
# VOICE_TRAINER_DESTINATION=      # default "user/model" destination in YOUR Replicate account

# ----- OWN MUSIC-MODEL TRAINING (the nightly compounding flywheel) ----------
# Fine-tunes OUR OWN music model on the rights-clean corpus (own-master /
# licensed / live-session / CONSENTED user-original — NEVER third-party
# renders). Trained weights land in YOUR Replicate account. Everything below is
# OFF by default: code never spends without the operator arming it.
#
# ── THE LICENSE UNLOCK (read this — it's why "approve training" must reach prod)
# The trained adapter INHERITS the base model's weight license. A MusicGen base
# is CC-BY-NC-4.0 (non-commercial): its adapter is license-capped to an isolated
# "dev" lane and can NEVER back a paying render — approving it changes nothing in
# production (this was the bug). To reach PRODUCTION you MUST train on an
# Apache-2.0 base (ACE-Step or YuE); those classify apache-2.0 and the promotion
# gate opens the production lane automatically.
#
# ── HONEST CAVEAT (the one external dependency you must supply)
# There is NO turnkey ACE-Step/YuE LoRA fine-tuner callable as a Replicate/fal
# model today (the ace-step we serve is INFERENCE-only; fine-tuning ACE-Step/YuE
# is a self-hosted GPU run via their repo trainer.py / one-click Gradio / ACE-
# Step's own hosted training endpoint). So the trainer ships UNCONFIGURED: set
# MUSIC_TRAINER_MODEL + MUSIC_TRAINER_VERSION to a REAL Apache-2.0 trainer ref
# (a Replicate model you host, or a hosted LoRA run) — the code is ready, this
# ref is the one thing only you can provide. Leaving it unset = honest logged
# skip, zero spend. (You MAY point it at sakemin/musicgen-fine-tuner to
# experiment, but its results stay dev-lane only — never production.)
#
# ── ARMING (all three needed for daily compounding to actually kick off) ──────
# 1) MUSIC_TRAINER_ENABLED=1        the ONLY spend gate; nightly flywheel runs
# 2) MUSIC_TRAINER_MODEL / _VERSION a real Apache-2.0 trainer (owner/name + hash)
# 3) REPLICATE_API_TOKEN set        (already required above for beats/vocals)
# Then the nightly compound job (daily ~02:45 UTC + after each deploy) manifests
# the rights-clean corpus, and — ONLY when it has >= MUSIC_TRAINER_MIN_CORPUS
# (default 20) reachable assets — zips it and kicks off a fine-tune. Score the
# finished candidate in Admin → Training candidates; an Apache candidate that
# wins promotes to production and the next render carries the trained layer.
# MUSIC_TRAINER_ENABLED=0
# MUSIC_TRAINER_MODEL=            # "owner/name" of a REAL Apache-2.0 trainer on Replicate
# MUSIC_TRAINER_VERSION=          # that trainer's exact version hash (never guessed)
# MUSIC_TRAINER_KIND=training     # 'training' (destination-based LoRA, default) | 'prediction'
# MUSIC_TRAINER_DATASET_KEY=dataset_zip   # the trainer's input field for the dataset zip
# MUSIC_TRAINER_DESTINATION=      # "user/model" in YOUR account; auto-created private if unset
# MUSIC_TRAINER_EXTRA_INPUT=      # optional JSON merged into the training input, e.g. {"lora_rank":16,"epochs":10}
# MUSIC_TRAINER_MIN_CORPUS=20     # min rights-clean assets before a fine-tune is worth spending on
# MUSIC_TRAINER_MAX_ASSETS=200    # cap per nightly dataset (disk/egress guard)
# MUSIC_TRAINER_MAX_RETRIES=1     # durable retries on a failed/canceled provider run
# MUSIC_TRAINER_PROMOTION_MIN_GAIN=1   # score a candidate must beat the incumbent by to promote
#
# ── Measured-audio referee (optional; OFF = text-judge only) ─────────────────
# When ON and a candidate-bound audio receipt exists, WER/FAD thresholds referee
# the score — a candidate that fails them cannot promote in ANY lane. Spends on
# the metrics harness only when armed.
# AUDIO_METRICS_ENABLED=0
# MUSIC_EVAL_MAX_WER=0.5          # reject a rendered vocal above this lyric WER
# MUSIC_EVAL_MAX_FAD_CLAP=        # optional FAD-CLAP cutoff vs AfroRef (advisory until set)
#
# ── Per-(genre|language) adapter routes (optional; OFF = single base pointer) ─
# MUSIC_ADAPTER_ROUTES_ENABLED=0

# ----- Frozen listening holdout (worker training/evaluation isolation) -----
# Keep OFF until the real nine-track manifest is frozen and deployed. Once the
# private holdout exists, turn this on so training fails closed if it disappears.
EAR_HOLDOUT_REQUIRED=0
# Optional override. Default resolves to apps/worker/py/fixtures/manifest.json.
# EAR_HOLDOUT_MANIFEST_PATH=

# ----- Guardrails & quality dials --------------------------------
# Internal-mode generation caps are enforced unless explicitly disabled with
# ENFORCE_GENERATION_CAP=0 for local development.
ENFORCE_GENERATION_CAP=1
MAX_DAILY_GENERATIONS=100
MAX_MONTHLY_GENERATIONS=2000
# Background schedules require both this switch and each admin autonomy flag.
ENABLE_AUTONOMY_CRON=0
# WO-1: admin/trigger routes (POST /admin/run etc.) require this header value as
# x-admin-secret. UNSET = admin routes locked (401 for everyone). Set a long
# random string on the API service; enter it once on the /admin page.
ADMIN_SECRET=
# Drop Machine regenerates hooks once if the best scores below this (0-10)
MIN_HOOK_SCORE=6.5
# WO-4(f): minimum measured lane score for a generated take to enter the
# reference lake (misses teach through the gap map, never the profile)
LANE_PROMOTE_MIN=70

# NOTE: fal.ai was REMOVED ENTIRELY (owner directive 2026-07-11). All renders
# run on the owner-approved Replicate configuration. A cheaper route re-enters
# only via a measured bake-off (the adapter lives in git history).

# A3-4 — stems routing: local = worker CPU Demucs (≈$0, slower), replicate =
# always paid. Unset default: nightly/measure = local, user-facing = paid.
DEMUCS_MODE=

# A3-5 — BULK brain (Cerebras, OpenAI-compatible). ONE org, Developer tier
# ($10 self-serve). CEREBRAS_API_KEYS accepts a comma list for concurrency
# WITHIN that org — never multi-account free-tier rotation. Judgment work
# (lyrics/hooks/A&R) ALWAYS stays on Anthropic regardless of these.
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# COST LAW — hard daily cap on BACKGROUND brain work (radar, lexicon mine/
# research/gloss/verify). Counts all llm.call events today; background tasks
# skip once crossed. User-facing creative work is charged/capped separately
# (WO-1). 0 = opt out.
BACKGROUND_LLM_DAILY_CAP=150

# ----- Release & distribution ------------------------------------
# ISRC registrant prefix (format CC-XXX, e.g. NG-AHS) — auto-assigns ISRCs on green-light
ISRC_PREFIX=
# GS1 company prefix (6-11 digits); leave empty for distributor assignment.
GS1_PREFIX=
# Signed outbound handoff to an approved distributor integration.
# Without an explicit partner name, submission URL, and secret, submission
# returns not_configured. Documentation placeholders never pass readiness.
DISTRIBUTOR=partner-name
DISTRIBUTOR_SUBMIT_URL=https://distribution-partner.example/releases
# Deprecated outbound URL alias. Keep empty when DISTRIBUTOR_SUBMIT_URL is set.
DISTRIBUTOR_WEBHOOK_URL=
DISTRIBUTOR_WEBHOOK_SECRET=
# Partner response must contain status submitted/accepted plus externalId.
# Requests carry x-afrohit-timestamp, x-afrohit-signature, and idempotency-key.
# Partner status callbacks POST to /webhooks/distributor with the same HMAC headers.
# Callback body requires a unique eventId, externalId, occurredAt, and status.
# Only a signed live callback marks the song RELEASED and public.

# ----- Trend research (all optional; graceful no-op when unset) ---
# YouTube Data API — legal chart-awareness from metadata only (never audio)
YOUTUBE_API_KEY=
BRAVE_API_KEY=

# ----- Worker ------------------------------------------------------
WORKER_CONCURRENCY=4
# Durable drop/material/A&R workflows run in the API process. Keep this low;
# each orchestration can fan out into several render jobs.
ORCHESTRATION_CONCURRENCY=1

# ----- Multi-tenant / go-live (added in the audit fix pass) -----
# Real auth: AUTH_MODE=jwt issues an HttpOnly signed session cookie. Bearer JWTs
# remain available for non-browser clients. Production refuses internal mode.
# ALLOW_STUB_AUDIO=1 permits placeholder audio/image/video in dev (blocked in prod).
# EXPOSE_DOCS=1 re-enables Swagger /docs in production (off by default).
