# ============================================================================
# AfroHit Studio — environment template
# Copy to .env (root) for local dev, and per-app .env in apps/{web,api,worker}
# ============================================================================

NODE_ENV=development
LOG_LEVEL=info
# Number of reverse-proxy hops trusted for client IPs in production.
TRUST_PROXY_HOPS=1

# ----- Public URLs -------------------------------------------------
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
WORKER_INTERNAL_URL=http://localhost:4100

# ----- Datastores --------------------------------------------------
# PostGIS + pgvector enabled Postgres (Railway template or local Docker)
DATABASE_URL=postgresql://afrohit:afrohit@localhost:5432/afrohit?schema=public

# Redis for BullMQ + cache
REDIS_URL=redis://localhost:6379

# ----- Object Storage (Railway Object Storage / Cloudflare R2 / S3) -
# Cloudflare R2? You can ALSO just set R2_S3_API_URL / R2_ACCOUNT_ID / R2_BUCKET /
# R2_PUBLIC_URL / R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY — the app reads both
# schemes (S3_* wins when both are set).
S3_ENDPOINT=https://your-bucket.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=afrohit-studio
# Production will not boot until the bucket is private and this is explicitly 1.
STORAGE_PRIVATE_CONFIRMED=0
S3_ACCESS_KEY=
S3_SECRET_KEY=
# New assets stay private and use stable s3:// references. Keep a public base
# only while migrating legacy rows; it is not used for new uploads.
# S3_PUBLIC_BASE_URL=https://cdn.afrohit.studio

# ----- Auth --------------------------------------------------------
# Production must use jwt. Internal mode always refuses to boot in production.
AUTH_MODE=jwt
JWT_SECRET=
IP_HASH_SECRET=
# Use "none" only for a truly cross-site web/API deployment over HTTPS.
SESSION_COOKIE_SAMESITE=lax
# Public account creation is closed by default in production.
ALLOW_PUBLIC_SIGNUP=0
INTERNAL_WORKSPACE_SLUG=studio
INTERNAL_OWNER_EMAIL=owner@afrohit.local

# ----- Billing (PayPal) -------------------------------------------
# Mode: "sandbox" for dev, "live" for production. The PayPal REST hostname
# is derived from this — no need to set it separately.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Webhook ID is created in the PayPal dashboard under Apps → My App → Webhooks.
# We need it to verify incoming webhook signatures.
PAYPAL_WEBHOOK_ID=
# Billing Plan IDs — create one Catalog Product + four Plans in PayPal once,
# then paste the Plan IDs (start with P-...) here.
PAYPAL_PLAN_STARTER=
PAYPAL_PLAN_CREATOR=
PAYPAL_PLAN_PRO=
PAYPAL_PLAN_STUDIO=
# Credit packs are just one-off Orders priced server-side; no product IDs needed.

# ----- AI Providers ------------------------------------------------
# OpenAI — the "writer": drafts hooks/lyrics for breadth, plus STT/TTS/images.
OPENAI_API_KEY=sk-xxx
# The flagship GPT — used when a call explicitly asks for the OpenAI brain
# (e.g. /admin → Writer A/B). Set gpt-5.6-sol ($5/$30 per M) to bench the
# newest GPT vs Claude; gpt-5.6-terra ($2.50/$15) is the Sonnet-priced tier.
OPENAI_TEXT_MODEL=gpt-4o
# GPT-5.x reasoning dials (ignored by non-reasoning models like gpt-4o):
# effort none|low|medium|high|xhigh|max (default medium — reasoning tokens
# bill as OUTPUT, so high+ costs real money per call), plus cap headroom so
# the thinking can't starve the visible lyric (default 12000 tokens).
# OPENAI_REASONING_EFFORT=medium
# OPENAI_REASONING_HEADROOM=12000
OPENAI_DRAFT_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_IMAGE_MODEL=gpt-image-1

# Anthropic — THE BRAIN (Claude-first for all creative work): hooks, lyrics,
# briefs, A&R critique, taste scoring, Studio Chat. If unset, the system falls
# back to GPT-only. Set on api + worker.
#
# MODEL — claude-sonnet-5 BY OWNER DIRECTIVE (2026-07-10). Fable 5 burned a
# $20 top-up in <2 songs: Mythos-class pricing PLUS its thinking tokens count
# against max_tokens, so the truncation guard re-ran big calls at double cap —
# many calls billed TWICE at flagship rates. Sonnet ran the same studio at
# $6-16/day. NEVER set claude-fable-5 here except for a deliberate, budgeted
# one-off pass. A Railway value OVERRIDES the code default — keep it sonnet or
# delete it. The refusal fallback (rare) retries once on Opus 4.8.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_FALLBACK_MODEL=claude-opus-4-8

# Tavily — live web trend research ("what's hot in Afrobeats right now").
# Optional; without it the research_trends tool is skipped. Set on api + worker.
TAVILY_API_KEY=

# Music generation providers
ELEVEN_API_KEY=
STABILITY_API_KEY=
MUBERT_API_KEY=
BEATOVEN_API_KEY=

# SUNO V5 — the strongest full-song (with-vocals) engine. THE biggest quality
# lever on how the studio SOUNDS. ACE-Step/MiniMax (Replicate) are sketch-grade
# and cannot match it. Set SUNO_API_KEY (a sunoapi.org key, or point
# SUNO_API_BASE at the official API) on BOTH services — the API (so every path's
# defaultSongEngine() auto-selects Suno) AND the WORKER (so the render can call
# it). Then all full songs upgrade at once, no code change. Optional SUNO_MODEL
# (default V5), SUNO_API_BASE.
SUNO_API_KEY=
# SUNO_MODEL=V5
# SUNO_API_BASE=https://api.sunoapi.org
# Force ONE engine for every vocal-song path (create page, chat, regenerate),
# overriding the auto Suno-if-keyed default. Leave unset unless you're testing a
# specific engine: suno | ace_step | minimax | replicate | stable_audio | mubert.
# SONG_ENGINE=suno

# WO-5 PROGRESSIVE BEST-OF-N — DRAFT default is 1 (cheapest first listen; the ear
# measures it regardless). Escalation is demand-driven: each "make it bigger" adds
# exactly ONE new take, compared against stored measurements — best-of-N is
# accumulated over time, never rendered blind upfront. Premium/Hit-Maker flows
# pass candidates:2 per request. Raise this only to change the DRAFT default.
BEST_OF_N=1

# ---- LANE PIPELINE cost gates (all DEFAULT-ON now for the testing phase) ----
# The ear/lane machinery. Each is ON unless set to 0. LANE_ASSESS: measure every
# render's lane + steer regens. DSP_STEMS: Demucs-stem-aware detection (the log drum
# lives in the bass stem). FILL_OVERLAY: lay drum fills into section transitions.
LANE_ASSESS=1
DSP_STEMS=1
FILL_OVERLAY=1
# NOTE: there is NO LOGDRUM_CALIBRATED flag. The log drum is a TRUTH gate — it
# calibrates via py/fixtures/logdrum_calibration.json (written by eval-ear.ts when the
# 9-track acceptance passes), never by a human toggle.

# Instrumental beat engine (the SUNG-song engine is chosen separately: Suno/
# MiniMax/ACE-Step). Must be a provider with a real adapter. 'stub' returns a
# placeholder — the worker now FAILS the render rather than shipping it, unless
# ALLOW_STUB_AUDIO=1 (dev only). Leave unset only if you don't render instrumentals.
# replicate (MusicGen) is the VALIDATED engine — it runs on the same
# REPLICATE_API_TOKEN you already have. eleven/stable_audio/mubert are
# UNVERIFIED scaffolds (endpoints guessed); pick them only after validating.
MUSIC_PROVIDER=replicate      # replicate is the VALIDATED default; eleven/stable_audio/mubert = UNVERIFIED scaffolds; stub = dev-only (hard-fails in prod)
# ALLOW_STUB_AUDIO=1          # dev only — permit the SoundHelix placeholder
VOICE_PROVIDER=eleven         # needs ELEVENLABS key + validation on YOUR account; stub hard-fails in prod
VIDEO_PROVIDER=veo            # veo/sora adapters are UNVERIFIED scaffolds — validate before relying on video
IMAGE_PROVIDER=openai         # validated (gpt-image-1 → dall-e-3 fallback); stub hard-fails in prod

# Video — Google Veo via Vertex AI
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GCP_SERVICE_ACCOUNT_JSON_B64=

# ----- Internal --------------------------------------------------
INTERNAL_API_SECRET=replace-with-at-least-32-random-bytes
# Generate once with: openssl rand -base64 32
ENCRYPTION_KEY=

# ----- Email (Resend) — transactional: welcome, job-done, receipts, drops --
RESEND_API_KEY=
EMAIL_FROM=AfroHit Studio <noreply@afrohit.studio>

# ----- Admin — comma-separated operator emails for /api/v1/admin/* ---------
ADMIN_EMAILS=

# ----- Observability ---------------------------------------------
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ----- Music brain (Replicate) — THE key that powers beats/vocals/stems/listen.
# Paste in-app (Settings → Music engine) or set here; the WORKER needs it too.
REPLICATE_API_TOKEN=
# Optional model overrides (defaults resolved at runtime)
# REPLICATE_MUSIC_MODEL= / REPLICATE_MUSIC_VERSION=
# REPLICATE_SONG_MODEL= / REPLICATE_SONG_VERSION=
# REPLICATE_MINIMAX_MODEL= / REPLICATE_MINIMAX_VERSION=
# REPLICATE_DEMUCS_MODEL= / REPLICATE_DEMUCS_VERSION=
# REPLICATE_TRANSCRIBE_MODEL= / REPLICATE_TRANSCRIBE_VERSION=
# REPLICATE_AUDIO_UNDERSTAND_MODEL= / REPLICATE_AUDIO_UNDERSTAND_VERSION=

# ----- VOICE TRAINING (own-voice singing model, Replicate trainings API) ----
# The artist trains a singing-voice model on HIS OWN recordings — his data,
# his rights. Trained weights land in YOUR Replicate account (the destination
# model below) — keep that destination model PRIVATE. Consent-gated: training
# requires a signed VoiceConsent row. Unset model/version → the API answers an
# honest 501 (voice_training_not_configured) instead of pretending.
#
# Picking a trainer: choose an RVC-family voice trainer of your choice on
# Replicate and pin its exact slug + version hash here — the code never
# guesses either. The base RVC lineage is MIT-licensed; a model trained
# exclusively on the artist's own recordings is the artist's.
#
# Dataset: ONE zip of clean SOLO vocals (wav/mp3), roughly 10-20 minutes total,
# no backing music/reverb — dry stems train best. Host it in app storage
# External dataset URLs are rejected unless ALLOW_EXTERNAL_VOICE_DATASET=1.
# ALLOW_EXTERNAL_VOICE_DATASET=0
# VOICE_TRAINER_MODEL=            # "owner/name" of the trainer on Replicate
# VOICE_TRAINER_VERSION=          # the trainer's version hash
# VOICE_TRAINER_DATASET_KEY=dataset_zip   # the trainer's input field for the zip (check its schema)
# VOICE_TRAINER_EXTRA_INPUT=      # optional JSON merged into the training input, e.g. {"epochs":80}
# VOICE_TRAINER_DESTINATION=      # default "user/model" destination in YOUR Replicate account

# ----- Guardrails & quality dials --------------------------------
# Internal-mode generation caps are enforced unless explicitly disabled with
# ENFORCE_GENERATION_CAP=0 for local development.
ENFORCE_GENERATION_CAP=1
MAX_DAILY_GENERATIONS=100
MAX_MONTHLY_GENERATIONS=2000
# Background schedules require both this switch and each admin autonomy flag.
ENABLE_AUTONOMY_CRON=0
# WO-1: admin/trigger routes (POST /admin/run etc.) require this header value as
# x-admin-secret. UNSET = admin routes locked (401 for everyone). Set a long
# random string on the API service; enter it once on the /admin page.
ADMIN_SECRET=
# Drop Machine regenerates hooks once if the best scores below this (0-10)
MIN_HOOK_SCORE=6.5
# WO-4(f): minimum measured lane score for a generated take to enter the
# reference lake (misses teach through the gap map, never the profile)
LANE_PROMOTE_MIN=70

# NOTE: fal.ai was REMOVED ENTIRELY (owner directive 2026-07-11). All renders
# run on the owner-approved Replicate configuration. A cheaper route re-enters
# only via a measured bake-off (the adapter lives in git history).

# A3-4 — stems routing: local = worker CPU Demucs (≈$0, slower), replicate =
# always paid. Unset default: nightly/measure = local, user-facing = paid.
DEMUCS_MODE=

# A3-5 — BULK brain (Cerebras, OpenAI-compatible). ONE org, Developer tier
# ($10 self-serve). CEREBRAS_API_KEYS accepts a comma list for concurrency
# WITHIN that org — never multi-account free-tier rotation. Judgment work
# (lyrics/hooks/A&R) ALWAYS stays on Anthropic regardless of these.
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# COST LAW — hard daily cap on BACKGROUND brain work (radar, lexicon mine/
# research/gloss/verify). Counts all llm.call events today; background tasks
# skip once crossed. User-facing creative work is charged/capped separately
# (WO-1). 0 = opt out.
BACKGROUND_LLM_DAILY_CAP=150

# ----- Release & distribution ------------------------------------
# ISRC registrant prefix (format CC-XXX, e.g. NG-AHS) — auto-assigns ISRCs on green-light
ISRC_PREFIX=
# Distribution seam (returns not_configured until set)
DISTRIBUTOR=
DISTRIBUTOR_API_KEY=
AUDIOMACK_API_KEY=

# ----- Trend research (all optional; graceful no-op when unset) ---
# YouTube Data API — legal chart-awareness from metadata only (never audio)
YOUTUBE_API_KEY=
BRAVE_API_KEY=

# ----- Worker ------------------------------------------------------
WORKER_CONCURRENCY=4

# ----- Multi-tenant / go-live (added in the audit fix pass) -----
# Real auth: AUTH_MODE=jwt issues an HttpOnly signed session cookie. Bearer JWTs
# remain available for non-browser clients. Production refuses internal mode.
# ALLOW_STUB_AUDIO=1 permits placeholder audio/image/video in dev (blocked in prod).
# Real distribution (RELEASED) needs a distributor account + key:
# DISTRIBUTOR=            # audiomack | boomplay | distrokid ... (adapter is stubbed until set)
# ISRC_PREFIX=           # your real 5-char IFPI registrant code (else ISRC is distributor-assigned)
# GS1_PREFIX=            # your real GS1 company prefix (else UPC is distributor-assigned)
# EXPOSE_DOCS=1 re-enables Swagger /docs in production (off by default).
