{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/worker/Dockerfile",
    "watchPatterns": [
      "/apps/worker/**",
      "/packages/**",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/package.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @afrohit/worker start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
