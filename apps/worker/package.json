{
  "name": "@afrohit/worker",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/test-all.ts",
    "test:live": "tsx scripts/test-all.ts -- --live",
    "training:run-now": "tsx scripts/run-training-now.ts",
    "ear:training-snapshot": "tsx scripts/export-ear-training-snapshot.ts",
    "ear:freeze": "tsx scripts/freeze-ear-corpus.ts",
    "ear:evaluate": "tsx scripts/eval-ear.ts",
    "audit:legacy-release-lineage": "tsx scripts/audit-legacy-release-lineage.ts",
    "test:legacy-release-lineage-audit": "tsx scripts/test-legacy-release-lineage-audit.ts",
    "test:release-lineage-integrity": "tsx scripts/test-release-lineage-integrity.mjs",
    "acceptance:readiness": "tsx scripts/run-acceptance-readiness.ts",
    "test:acceptance-readiness": "tsx scripts/test-acceptance-readiness.ts",
    "typecheck:shim": "tsc -p tsconfig.shim.json --noEmit"
  },
  "dependencies": {
    "@afrohit/ai": "workspace:*",
    "@afrohit/db": "workspace:*",
    "@afrohit/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@sentry/node": "^10.66.0",
    "bullmq": "^5.80.9",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "jszip": "^3.10.1",
    "nanoid": "^6.0.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
