{
  "name": "@afrohit/worker",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/test-all.ts",
    "test:live": "tsx scripts/test-all.ts -- --live",
    "test:release-lineage-integrity": "tsx scripts/test-release-lineage-integrity.mjs",
    "typecheck:shim": "tsc -p tsconfig.shim.json --noEmit"
  },
  "dependencies": {
    "@afrohit/ai": "workspace:*",
    "@afrohit/db": "workspace:*",
    "@afrohit/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.1088.0",
    "@aws-sdk/s3-request-presigner": "^3.1088.0",
    "@sentry/node": "^10.55.0",
    "bullmq": "^5.80.4",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "jszip": "^3.10.1",
    "nanoid": "^6.0.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
