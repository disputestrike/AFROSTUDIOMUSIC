{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": { "nixPkgs": ["nodejs_20", "openssl"] },
        "install": {
          "cmds": [
            "npm install -g pnpm@9.12.0",
            "pnpm install --frozen-lockfile --prod=false"
          ]
        },
        "build": {
          "cmds": [
            "pnpm --filter @afrohit/db generate",
            "pnpm --filter @afrohit/shared build",
            "pnpm --filter @afrohit/db build",
            "pnpm --filter @afrohit/ai build",
            "pnpm --filter @afrohit/api build"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "pnpm --filter @afrohit/db migrate:deploy && pnpm --filter @afrohit/api start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
