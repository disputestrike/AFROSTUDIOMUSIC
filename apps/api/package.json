{
  "name": "@afrohit/api",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "typecheck:shim": "tsc -p tsconfig.shim.json --noEmit",
    "test:distribution-lifecycle": "tsx scripts/test-distribution-lifecycle.ts",
    "test:credit-caps": "tsx scripts/test-credit-caps.ts",
    "test:payment-lifecycle": "tsx scripts/test-payment-lifecycle.ts",
    "test:drop-terminal-integrity": "tsx scripts/test-drop-terminal-integrity.ts",
    "test:album-generation-integrity": "tsx scripts/test-album-generation-integrity.ts",
    "test:current-playable-asset": "tsx scripts/test-current-playable-asset.ts",
    "test:rights-zap-ingress": "tsx scripts/test-rights-zap-ingress.ts",
    "test:release-artifact-integrity": "tsx scripts/test-release-artifact-integrity.ts",
    "test:platform-reliability": "tsx scripts/test-platform-reliability.ts",
    "test:benchmark-pair-attestation": "tsx scripts/test-benchmark-pair-attestation.ts",
    "test:session-revocation": "tsx scripts/test-session-revocation.ts"
  },
  "dependencies": {
    "@afrohit/ai": "workspace:*",
    "@afrohit/db": "workspace:*",
    "@afrohit/shared": "workspace:*",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/sensible": "^6.0.1",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@aws-sdk/client-s3": "^3.1088.0",
    "@aws-sdk/s3-request-presigner": "^3.1088.0",
    "@sentry/node": "^10.55.0",
    "bullmq": "^5.80.4",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^7.0.0",
    "ioredis": "^5.11.1",
    "nanoid": "^6.0.0",
    "openai": "^6.47.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
